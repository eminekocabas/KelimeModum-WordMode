  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 5f7201a12d95ffc409449d95f23cf332, type: 3}
  m_Name: 
  m_EditorClassIdentifier: UnityEngine.UI::UnityEngine.UI.Text
  m_Material: {fileID: 0}
  m_Color: {r: 0.19607843, g: 0.19607843, b: 0.19607843, a: 1}
  m_RaycastTarget: 1
  m_RaycastPadding: {x: 0, y: 0, z: 0, w: 0}
  m_Maskable: 1
  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_FontData:
    m_Font: {fileID: 12800000, guid: c767620e1231cd741b639f490ebf25bc, type: 3}
    m_FontSize: 40
    m_FontStyle: 0
    m_BestFit: 0
    m_MinSize: 0
    m_MaxSize: 50
    m_Alignment: 0
    m_AlignByGeometry: 0
    m_RichText: 1
    m_HorizontalOverflow: 0
    m_VerticalOverflow: 1
    m_LineSpacing: 1
  m_Text: "Ama\xE7, kelimeyi s\u0131n\u0131rl\u0131 say\u0131da tahminde bulmakt\u0131r.\n\nOyun
    ba\u015Flamadan \xF6nce oynamak istedi\u011Fin modunu ve kelime uzunlu\u011Funu
    se\xE7.\n\nModlar:\n\nG\xFCnl\xFCk Kelime: Her g\xFCn yeni bir kelime y\xFCklenir
    ve en y\xFCksek puanl\u0131 modun.\n\nSonsuz Mod: \u0130stedi\u011Fin kadar \xFCst
    \xFCste oynayabilce\u011Fin modun.\n\nS\xFCreli Mod:  Belirledi\u011Fin s\xFCrede
    kelimeyi bulmaya \xE7al\u0131\u015F. \u0130lk harfi verilir. S\xFCre ne kadar
    azsa o kadar fazla puan alabilece\u011Fin modun.\n\nHer tahminden sonra harflerin
    rengi ipucu verir:\n\n       Ye\u015Fil: Harf do\u011Fru ve do\u011Fru yerde\n\n      
    Sar\u0131: Harf do\u011Fru ama yeri yanl\u0131\u015F\n\n       Gri: Harf kelimede
    yok\n\n\u0130pu\xE7lar\u0131n\u0131 kullanarak bir sonraki tahminini yap.\n\nKelimeyi
    t\xFCm haklar\u0131n bitmeden bulursan kazan\u0131rs\u0131n.\n\nDaha az denemede
    bulmak kazand\u0131\u011F\u0131n puan\u0131 artt\u0131r\u0131r.\n\nYa zor mod
    neydi?\nGri g\xF6stergeli harfleri kullanmana izin vermez. \xC7ok daha fazla
    kelime t\xFCretmelisin.\n\nK\xFC\xE7\xFCk bir ipucu: Zor modda kazan\u0131lan
    t\xFCm oyunlar x2 puan kazand\u0131r\u0131r."
